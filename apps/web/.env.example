# Supabase — public anon key (safe to expose; RLS restricts to read-only)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only — enables the dev-only "trash junk artist" button (never sent to the
# browser; the admin route 404s outside `next dev`). Same key as pipeline/.env.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-side only — shared secret that lets the solo operator use the "fetch images" button on
# the LIVE deployed site (the route 404s for anyone without it). Set this in Vercel env. Visit
# https://<site>/artists?admin=<this-value> once to store the token in your browser; the button
# then appears and replays it as the x-admin-token header. Leave unset to keep fetch-images
# dev-only. Lightweight gate, not real auth — don't reuse it for anything destructive.
ADMIN_TOKEN=pick-a-long-random-string

# Server-side only — powers the dev-only "fetch images from Instagram" button on the artist
# page (RapidAPI scraper, no Apify credits). The route 404s outside `next dev`.
# Pick any Instagram scraper on RapidAPI, then paste its key, host, and the exact request URL
# from the provider's code snippet — put {handle} where the username goes. Provider-agnostic:
# the JSON shape doesn't matter, we harvest Instagram-CDN image URLs from the whole response.
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_INSTAGRAM_HOST=instagram-scraper-stable-api.p.rapidapi.com
RAPIDAPI_INSTAGRAM_URL=https://instagram-scraper-stable-api.p.rapidapi.com/get_media_data.php?username_or_url={handle}&type=posts
