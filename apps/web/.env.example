# Supabase — public anon key (safe to expose; RLS restricts to read-only + the signed-in user's
# own favorites). Also used by @supabase/ssr for the Google auth session.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only — lets the curation routes (delete-artist, fetch-images, recrawl-shop) perform
# privileged writes after they've authorized the caller by role. Never sent to the browser. Same
# key as pipeline/.env.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-side only — the operator's Google account email. Whoever logs in with this address is
# treated as "owner" (full access) without any DB row. Elevate others to admin in SQL:
#   update profiles set role = 'admin' where email = '...';
OWNER_EMAIL=you@example.com

# Server-side only — powers the admin "fetch images from Instagram" button (RapidAPI scraper, no
# Apify credits). Pick any Instagram scraper on RapidAPI, then paste its key, host, and the exact
# request URL from the provider's code snippet — put {handle} where the username goes.
# Provider-agnostic: the JSON shape doesn't matter, we harvest Instagram-CDN image URLs from the
# whole response.
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_INSTAGRAM_HOST=instagram-scraper-stable-api.p.rapidapi.com
RAPIDAPI_INSTAGRAM_URL=https://instagram-scraper-stable-api.p.rapidapi.com/get_media_data.php?username_or_url={handle}&type=posts
