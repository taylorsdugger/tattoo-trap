# Supabase — public anon key (safe to expose; RLS restricts to read-only)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only — enables the dev-only "trash junk artist" button (never sent to the
# browser; the admin route 404s outside `next dev`). Same key as pipeline/.env.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
