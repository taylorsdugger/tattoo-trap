# Supabase — service role key (server-side only, NEVER ship to the browser)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Google Places enrichment for seeding shops. Leave blank to seed from CSV only.
GOOGLE_PLACES_API_KEY=

# Optional: Apify token for sourcing portfolio images from Instagram (`make scrape-ig`).
# Token: https://console.apify.com/account/integrations
# IMPORTANT: also set a $5 max monthly spend limit in the Apify console
# (Settings -> Limits) — that's the authoritative cap that keeps you inside the free credit.
APIFY_TOKEN=
